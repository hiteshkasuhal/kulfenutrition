.rich_text.presets.rich_text.name","settings":{"color_scheme":"scheme-7d9f776e-cbed-4177-b364-8a5ef46616cd","separate_section_with_border":true,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"video_7y6EdP":{"type":"video","blocks":{"play_MPwHpr":{"type":"play","settings":{"icon_color":"#ffffff"}}},"block_order":["play_MPwHpr"],"name":"t:sections.video.presets.video.name","settings":{"autoplay":true,"show_controls":true,"video_size":"md","video":"shopify:\/\/files\/videos\/copy_69E3ED6F-0A34-4416-A124-7CB379D8A081.MOV","external_video_url":"","text_color":"#ffffff"}},"174550524596864e48":{"type":"apps","blocks":{"judge_me_reviews_featured_carousel_G6HGCx":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/featured_carousel\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{"maxwidth":1080}}},"block_order":["judge_me_reviews_featured_carousel_G6HGCx"],"settings":{"color_scheme":"scheme-7d9f776e-cbed-4177-b364-8a5ef46616cd","separate_section_with_border":true,"remove_vertical_spacing":false,"remove_horizontal_spacing":false}},"image_with_text_pbh46b":{"type":"image-with-text","blocks":{"subheading_fXMePN":{"type":"subheading","settings":{"text":"<strong>Meet Aresh, Founder of Kulfé<\/strong>"}},"heading_Q8kELd":{"type":"heading","settings":{"text":"From Coney Island Sweets to Gym Gains","heading_tag":"h1"}},"richtext_tnzVzQ":{"type":"richtext","settings":{"content":"<p>Hey, I’m <strong>Aresh Saqib<\/strong>—avid gym-goer, foodie, and proud son of two Pakistani parents.<\/p><p>Growing up in Brooklyn’s Desi community (yes, <em>that<\/em> Coney Island), my life was basically a never-ending hunt for the best desserts. But as I got older, my stomach and macros weren’t loving those extra calories and sugar highs (sorry, Mom).<\/p><p>Like every gym bro, I needed more protein—200g a day if you listen to the “experts.” But after choking down my 10th sad chocolate protein shake, I thought… why can’t protein taste like <em>actual<\/em> desserts?<\/p><p>That’s when the idea for Falooda Protein was born! No shortcuts, no chalky aftertaste—just legit South Asian flavor nostalgia and high-quality whey isolate. Add it to Greek yogurt, or—my hack—throw it in the Ninja Creami for a dessert you <em>won’t<\/em> regret.<\/p><p>So if you’re tired of boring protein and love good food, welcome to the fam.<\/p><p><strong>Family-Owned • Heritage-Driven • Made for Foodies & Fitness Fans<\/strong><\/p>"}}},"block_order":["subheading_fXMePN","heading_Q8kELd","richtext_tnzVzQ"],"name":"t:sections.image_with_text.presets.image_with_text.name","settings":{"color_scheme":"scheme-7d9f776e-cbed-4177-b364-8a5ef46616cd","separate_section_with_border":true,"image":"shopify:\/\/shop_images\/D553C2B9-1F90-438C-B46F-8684BC12D3B4.jpg","mobile_image":"shopify:\/\/shop_images\/D553C2B9-1F90-438C-B46F-8684BC12D3B4.jpg","reveal_on_scroll":true,"image_position":"start","content_width":"sm","remove_vertical_spacing":true}},"multi-column":{"type":"multi-column","blocks":{"column-1":{"type":"image_with_text","settings":{"title":"Supports Balanced Blood Sugar title","heading_tag":"h3","content":"<p>Formulated with clean ingredients to help support healthy blood sugar levels — so you feel your best, naturally.<\/p><h3><\/h3>","link_url":"","link_text":""}},"column-2":{"type":"image_with_text","settings":{"title":"Keeps You Full & Satisfied","heading_tag":"h3","content":"<p>With 21g of protein per serving, Kulfé keeps you feeling fuller for longer — making it easier to fuel your day without constant snacking.<\/p><h3><\/h3>","link_url":"","link_text":""}},"column-3":{"type":"image_with_text","settings":{"title":"Tastes Like Dessert, Feels Like Wellness","heading_tag":"h3","content":"<p>Inspired by South Asian flavors — every sip is a reminder that nourishing your body should feel indulgent.<\/p>","link_url":"","link_text":""}}},"block_order":["column-1","column-2","column-3"],"settings":{"color_scheme":"scheme-7d9f776e-cbed-4177-b364-8a5ef46616cd"