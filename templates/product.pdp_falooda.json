        "faq_LF4zGm": {
          "type": "faq",
          "settings": {
            "question": "Description",
            "answer": "<p>Falooda Protein brings the nostalgia of falooda to modern nutrition.</p><p>Each scoop delivers <strong>21g of pure whey</strong> protein with the rich taste of rose, cardamom, and vanilla — crafted for easy digestion, clean energy, and real results.</p><p>A protein shake that finally tastes as good as it feels</p>",
            "custom_class": "pdt_faq pdt_faq_1 mobile_only below_media"
          }
        },
        "faq_nPyjh6": {
          "type": "faq",
          "settings": {
            "question": "How to Use",
            "answer": "<p>1. Add <strong>1 scoop (33g)</strong> of Falooda Protein to <strong>250 ml</strong> of cold milk or water.<br/><br/>2. Shake or blend well until smooth and creamy.<br/>Enjoy it post-workout for recovery or anytime during the day as a nourishing snack or meal boost.<br/><br/>💡 <strong>Tip:</strong> Mix it with chilled milk for a rich falooda-like experience, or blend with oats, banana, or ice for a thicker shake.</p>",
            "custom_class": "pdt_faq pdt_faq_2 mobile_only below_media"
          }
        },
        "faq_GqUCci": {
          "type": "faq",
          "settings": {
            "question": "Ingredients",
            "answer": "<p>Whey Protein concentrate (90%), Natural Rose Extract, Cardamom Extract, Vanilla Flavoring, Digestive Enzyme Blend, Natural Sweetener (Stevia), Sucralose, Stabilizers, and Flavor Enhancers (Natural Origin).</p><ul><li>No Artificial Colors or Dyes.</li><li>No Added Preservatives</li><li>Just 2g of Total Sugar and 21g of Protein Per Serving. </li></ul>",
            "custom_class": "pdt_faq pdt_faq_3 mobile_only below_media"
          }
        },
