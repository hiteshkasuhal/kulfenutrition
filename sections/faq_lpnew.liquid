
{%- style -%}
  
{% if section.settings.bg != blank %}
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: bottom;
    }
  {% endif %}
{% if section.settings.bg_mobile != blank %}
  @media screen and (max-width: 915px) {
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg_mobile | image_url}});
    }
  }
  {% endif %}
  @media screen and (max-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  @media screen and (min-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="faq_custom section_bg_{{ section.id }} {{ section.settings.custom_class }}"{% if section.settings.custom_id != blank %} id="{{ section.settings.custom_id }}"{% endif %}
style="background-color:{{ section.settings.bg_color | default:'transparent' }};color:{{ section.settings.color | default:'#000' }};">
   <div class="container_hk section-{{ section.id }}-padding isolate">
       {% if section.settings.heading != blank %}
     <div class="faq_top left">
      <h2 class="rich-text__heading  inline-richtext h1">{{ section.settings.heading }}</h2>
       <div class="faq_subtext">{{ section.settings.text }}</div>
     </div>
       {% endif %}
{% assign  total_faqs = section.blocks.size %}
{% assign  half_extra = total_faqs | modulo:2 %}
     {% if half_extra > 0 %}
{% assign  half_faqs = total_faqs | divided_by:2 | plus: 1 %}
       {% else %}
{% assign  half_faqs = total_faqs | divided_by:2  %}
     {% endif %}

     <div class="faq_center">
       <div class="faq_center_main">
        {%- for block in section.blocks -%}
              {%- if block.settings.question != blank -%}
                {% if forloop.index <= half_faqs %}
       <div class="faq_slider_item">
       <div class="faq_slider_item_inner">
          <div class="faq_question">
           <span>{{ block.settings.question }}</span>
          </div>
          <div class="faq_answer" style="display:none;">
            {{ block.settings.answer }}
          </div>
       </div>
           </div>
              {%- endif -%}
              {%- endif -%}
       {% endfor %}
       </div>
       
       <div class="faq_center_main">
        {%- for block in section.blocks -%}
              {%- if block.settings.question != blank -%}
                {% if forloop.index > half_faqs %}
       <div class="faq_slider_item">
       <div class="faq_slider_item_inner">
          <div class="faq_question">
           <span>{{ block.settings.question }}</span>
          </div>
          <div class="faq_answer" style="display:none;">
            {{ block.settings.answer }}
          </div>
       </div>
           </div>
              {%- endif -%}
              {%- endif -%}
       {% endfor %}
       </div>
     </div>
      
     
   </div>
  </div>

{% schema %}
  {
    "name": "FAQ LPnew",
    "settings": [
      {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    },
      {
      "type": "image_picker",
      "id": "bg",
      "label": "Section Background"
    },
      {
      "type": "image_picker",
      "id": "bg_mobile",
      "label": "Section Background"
    },
     {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color"
    },
     {
      "type": "color",
      "id": "color",
      "label": "Section Text Color"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 50
    }
    ],
  "blocks": [
     {
      "type": "faq",
      "name": "FAQ",
      "settings": [
         {
          "type": "inline_richtext",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ LPnew"
    }
  ]
  }
{% endschema %}