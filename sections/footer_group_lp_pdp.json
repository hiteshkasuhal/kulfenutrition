          type=\"email\"\n                    name=\"contact[email]\"\n                    class=\"field__input_lp\"\n                    value=\"{{ form.email }}\"\n                    aria-required=\"true\"\n                    autocorrect=\"off\"\n                    autocapitalize=\"off\"\n                    autocomplete=\"email\"\n                    {% if form.errors %}\n                      autofocus\n                      aria-invalid=\"true\"\n                      aria-describedby=\"Newsletter-error--{{ section.id }}\"\n                    {% elsif form.posted_successfully? %}\n                      aria-describedby=\"Newsletter-success--{{ section.id }}\"\n                    {% endif %}\n                    placeholder=\"Enter your email\"\n                    required\n                  >\n                   <button\n                    type=\"submit\"\n                    class=\"submit_button\"\n                    name=\"commit\"\n                    id=\"Subscribe\"\n                    aria-label=\"{{ 'newsletter.button_label' | t }}\"\n                  >Subscribe<\/button>\n                <\/div>\n                {%- if form.errors -%}\n                  <small class=\"error_lp\">\n                    {{- form.errors.translated_fields.email | capitalize }}\n                    {{ form.errors.messages.email -}}\n                  <\/small>\n                {%- endif -%}\n              <\/div>\n              {%- if form.posted_successfully? -%}\n                <h3\n                  class=\"success_lp\"\n                  id=\"Newsletter-success--{{ section.id }}\"\n                  tabindex=\"-1\"\n                  autofocus\n                >\n                  {{- 'newsletter.success' | t }}\n                <\/h3>\n              {%- endif -%}\n            {% endform %}\n<\/div>\n<\/div>","custom_class":"kulfe_footer_form"}},"richtext_3aNXL3":{"type":"richtext","settings":{"text":"<p>Menu<\/p><ul><li><a href=\"\/search\" title=\"\/search\">Search<\/a><\/li><li><a href=\"\/pages\/affiliates\" title=\"Affiliates\">Affiliates<\/a><\/li><li><a href=\"\/pages\/data-sharing-opt-out\" title=\"Your privacy choices\">Your privacy choices<\/a><\/li><li><a href=\"\/policies\/shipping-policy\" title=\"Shipping Policy\">Shipping Policy<\/a><\/li><li><a href=\"\/policies\/refund-policy\" title=\"Refund Policy\">Refund Policy<\/a><\/li><li><a href=\"\/policies\/privacy-policy\" title=\"Privacy Policy\">Privacy Policy<\/a><\/li><li><a href=\"\/policies\/terms-of-service\" title=\"Terms of Service\">Terms of Service<\/a><\/li><\/ul>","html":"","custom_class":"kulfe_footer_menu"}},"richtext_AEpwqE":{"type":"richtext","settings":{"text":"<p>About us<\/p><p>Rooted in tradition, crafted for today.<\/p><p>At Kulfé Nutrition, we blend South Asian nostalgia with modern wellness - creating protein powders inspired by the flavors we grew up loving. Every scoop is a reminder that taking care of yourself should feel good, taste good,and honor where you come from.<\/p><p>Fuel your day, <em>the Kulfé way.<\/em><\/p>","html":"","custom_class":"kulfe_footer_text"}},"richtext_6rETbH":{"type":"richtext","settings":{"text":"","html":"© {{ \"now\" | date: \"%Y\" }} - Kulfe Nutrition. All rights reserved.","custom_class":"kulfe_footer_copyright desktop_only"}},"richtext_7AtGWx":{"type":"richtext","settings":{"text":"<p>Country\/region<\/p>","html":"{% form 'localization' %}\n  <select name=\"country_code\" id=\"country_selector\">\n    {% assign current_country = localization.country %}\n    <option value=\"{{ current_country.iso_code }}\">\n      {{ current_country.name }} ({{ current_country.currency.iso_code }} {{ current_country.currency.symbol }})\n    <\/option>\n\n    {% for country in localization.available_countries %}\n      {% unless country.iso_code == current_country.iso_code %}\n        <option value=\"{{ country.iso_code }}\">\n          {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})\n        <\/option>\n      {% endunless %}\n    {% endfor %}\n  <\/select>\n{% endform %}\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const selector = document.getElementById(\"country_selector\");\n    if (selector) {\n      selector.addEventListener(\"change\", function () {\n        this.form.submit();\n      });\n    }\n  });\n<\/script>","custom_class":"kulfe_footer_text3"}},"image_DAhinD":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/kulfe_footer_brand.webp","loading":"eager","fetchpriority":"high","custom_class":"kulfe_footer_brand"}},"richtext_FBijqN":{"type":"richtext","settings":{"text":"<p>© 2025 - Kulfe Nutrition. All rights reserved.<\/p>","html":"","custom_class":"kulfe_footer_copyright mobile_only"}}},"block_order":["image_with_link_XkYUKi","html_VJaCp9","richtext_WCeR7n","richtext_3aNXL3","richtext_AEpwqE","richtext_6rETbH","richtext_7AtGWx","image_DAhinD","richtext_FBijqN"],"name":"Richtext Lpnew","settings":{"custom_class":"kulfe_footer_section","custom_id":"","svg_desktop":"","svg_mobile":"","svg_desktop2":"","svg_mobile2":"","bg_color":"#000000","bg_color2":"","color":"#ffffff","position":"left","padding_top":60,"padding_bottom":60,"padding_top_mobile":30,"padding_bottom_mobile":30,"trigger_class":""}}},"order":["richtext_lpnew_TcB3dc"]}