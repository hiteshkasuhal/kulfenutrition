    <div class="cart_rating_top_new">{{ section.settings.rating_svg }}<span>{{ section.settings.rating_text }}</span></div>

</div>
    <div class="cart_free_bar">
{% assign total_price_cart = cart.total_price %}
{% assign threshold = section.settings.threshold | times:100 %}
{% assign price_left = threshold | minus:cart.total_price | money %}
{% if total_price_cart < threshold %}
{% assign percentage_left = cart.total_price | times:100 | divided_by:threshold | round %}
  {% endif %}
{% if total_price_cart >= threshold %}
{% assign percentage_left =  100 %}
  {% endif %}
            <div class="free_shipping_bar">
            <div class="free_shipping_bar_inner">
            <div class="free_shipping_bar_top">
            <div class="free_shipping_unlocked trigger_unlock"{% if total_price_cart < threshold %} style="display:none;"{% endif %}>{{ section.settings.shipping_svg }}<span>{{ section.settings.shipping_unlocked }}</span></div>
            <div class="free_shipping_locked trigger_lock"{% if total_price_cart >= threshold %} style="display:none;"{% endif %}>{{ section.settings.shipping_svg }}<span>{{ section.settings.shipping_locked | replace:'[price]',price_left }}</span></div>
            </div>
            <div class="free_shipping_bar_bttom">
            <div class="free_shipping_bar_unfill"><div class="free_shipping_bar_fill" style="width:{{ percentage_left }}%;"><span>{% if percentage_left != 100 %}{{ percentage_left }}%{% else %}{{ section.settings.shipping_svg2 }}{% endif %}</span></div>
            </div>
            </div>
            </div>
            </div>
      
    </div>
      <div class="cart_middle">
      <div class="cart_items_main">
        
    {%- assign seen_variants = '' -%}
   {% for item in cart.items %}
    {%- comment -%} detect duplicates by variant id {%- endcomment -%}
{%- assign needle   = ',' | append: item.variant.id | append: ',' -%}
{%- assign haystack = ',' | append: seen_variants    | append: ',' -%}
{%- assign is_duplicate = false -%}
{%- if haystack contains needle -%}
  {%- assign is_duplicate = true -%}
{%- else -%}
  {%- assign seen_variants = seen_variants | append: item.variant.id | append: ',' -%}
{%- endif -%}
      <div class="cart_item_single{% if is_duplicate %} is-duplicate{% else %} is-primary{% endif %}"{% if is_duplicate %} style="display:none;"{% endif %}
     data-variant-id="{{ item.variant.id }}"
     data-key="{{ item.key }}">
      <div class="cart_item_single_flex">
      <div class="cart_item_single_left">
  {% if item.product.metafields.custom.cart_featured_image != blank %}
  <img class="item_image" alt="{{ item.product.title }}" src="{{ item.product.metafields.custom.cart_featured_image | image_url }}" loading="eager" width="auto" height="auto" fetchpriority="high">
 {% else %}
  <img class="item_image" alt="{{ item.product.title }}" src="{{ item.product.featured_image | image_url }}" loading="eager" width="auto" height="auto" fetchpriority="high">
  {%endif %}
      </div>
      <div class="cart_item_single_right">
      <div class="cart_item_single_right_title_flex">
      <div class="cart_item_single_right_title_left">
      <div class="cart_item_single_title">{{ item.product.title }}</div> 
          {% if item.options_with_values.size > 0 %}
  <ul class="cart_item_options">
    {% for option in item.options_with_values %}
      <li>{{ option.name }}: {{ option.value }}</li>
    {% endfor %}
  </ul>
{% endif %}
        
      {% if item.selling_plan_allocation.selling_plan.id != blank %}
     <div class="cart_item_single_selling_plan">{{ item.selling_plan_allocation.selling_plan.name }}</div>
    {% endif %}
    
  {%- assign variant_id = item.variant.id -%}
  {%- assign total_final = 0 -%}
  {%- assign total_original = 0 -%}
{%- assign total_qty = 0 -%}
 {%- for li in cart.items -%}
    {%- if li.variant.id == variant_id -%}
      {%- assign total_final = total_final | plus: li.final_line_price -%}
      {% if li.variant.compare_at_price  > li.variant.price %}
      {%- assign compare_orignal = li.variant.compare_at_price | times: li.quantity -%}
      {%- assign total_original = total_original | plus: compare_orignal -%}
      {% else %}
      {%- assign total_original = total_original | plus: li.original_line_price -%}
      {% endif %}
    {%- assign total_qty = total_qty | plus: li.quantity -%}
    {%- endif -%}
  {%- endfor -%}
      <div class="cart_item_single_right_bottom_right">
        <div class="cart_quantity_wrapper">
        <div class="cart_quantity_button quantity_minus">-</div>
         <!-- real qty (readonly + hidden visually) -->
      <input name="quantity_single"
             type="number"
             value="{{ item.quantity }}"
             key="{{ item.key }}"
             variant_id="{{ item.variant.id }}"
             {% if item.selling_plan_allocation.selling_plan.id != blank %} 
               selling_plan="{{ item.selling_plan_allocation.selling_plan.id }}"
             {% endif %}
             readonly style="display:none;">
      
      <!-- fake qty (sum of paid + free) -->
<input class="fake_quantity_display"
       type="number"
       value="{{ total_qty }}"
       readonly>



        <div class="cart_quantity_button quantity_plus">+</div>
        </div>
        
      <div class="stock_cart"><span class="stock_outer"><span class="stock_inner"></span></span>In stock</div>
      </div>
      </div>
      <div class="cart_item_single_right_title_right">
      <div class="cart_item_single_right_title_right_price"> 
          <div class="cart_item_single_price">{{ total_final | money }}</div>
  {%- if total_original > total_final -%}
    <div class="cart_item_single_price_compare">{{ total_original | money }}</div>
    <div class="cart_item_single_price_save">Save {{ total_original | minus:total_final | money_without_trailing_zeros }}</div>
  {%- endif -%}
      </div>
      <div class="cart_item_single_right_remove remove-variant-{{ item.variant.id }}" line="{{ forloop.index }}"
       key="{{ item.key }}"
       variant_id="{{ item.variant.id }}"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
  <path d="M4 6.33594H5.33333H16" stroke="black" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M14.6673 6.33073V15.6641C14.6673 16.0177 14.5268 16.3568 14.2768 16.6069C14.0268 16.8569 13.6876 16.9974 13.334 16.9974H6.66732C6.3137 16.9974 5.97456 16.8569 5.72451 16.6069C5.47446 16.3568 5.33398 16.0177 5.33398 15.6641V6.33073M7.33399 6.33073V4.9974C7.33399 4.64377 7.47446 4.30464 7.72451 4.05459C7.97456 3.80454 8.3137 3.66406 8.66732 3.66406H11.334C11.6876 3.66406 12.0267 3.80454 12.2768 4.05459C12.5268 4.30464 12.6673 4.64377 12.6673 4.9974V6.33073" stroke="black" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div>
      </div>
      </div>
      </div>
      </div>
      </div>
          {% endfor %}
      </div>
        {% if section.settings.recommended_product != blank %}
          {% assign recommended_product = section.settings.recommended_product  %}
          <div class="recommended_product_main">
        {% if section.settings.recommended_title != blank %}
