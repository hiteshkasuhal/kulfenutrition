</svg></a></li>
      {% endfor %}
  </ul>
</div>
<div class="menu_drawer_bottom">
<a class="account_icon_mb_" href="/account"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
  <path d="M12.0939 4.5625C11.9559 6.421 10.5466 7.9375 9.00011 7.9375C7.45361 7.9375 6.04211 6.42175 5.90636 4.5625C5.76611 2.629 7.13636 1.1875 9.00011 1.1875C10.8631 1.1875 12.2349 2.66425 12.0939 4.5625Z" stroke="#1C1C1C" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M2.2627 15.5602C2.8372 12.375 5.94145 10.6875 8.99995 10.6875C12.0584 10.6875 15.1627 12.375 15.7379 15.5602" stroke="#1C1C1C" stroke-width="1.2" stroke-miterlimit="10"/>
</svg> Log in</a>

       {% form 'localization' %}
  <select name="country_code" id="country_selector_header2">
    {% assign current_country = localization.country %}
    <option value="{{ current_country.iso_code }}">
      {{ current_country.currency.iso_code }} {{ current_country.currency.symbol }}
    </option>

    {% for country in localization.available_countries %}
      {% unless country.iso_code == current_country.iso_code %}
        <option value="{{ country.iso_code }}">
          {{ country.currency.iso_code }} {{ country.currency.symbol }}
        </option>
      {% endunless %}
    {% endfor %}
  </select>
{% endform %}

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const selector = document.getElementById("country_selector_header2");
    if (selector) {
      selector.addEventListener("change", function () {
        this.form.submit();
      });
    }
  });
</script>
</div>
</div>

<!-- Drawer Overlay -->
<div class="custom_overlay" style="display:none;"></div>
<div class="custom_overlay2" style="display:none;"></div>

<!-- Cart Drawer -->
<div id="cart-drawer" class="cart-drawer{% if cart.item_count == 0 %} is_empty{% endif %}" style="background-color:{{ section.settings.bg_color | default:'transparent' }};color:{{ section.settings.color | default:'#000' }}">
  <button id="cart-close" class="cart-close">{{ section.settings.svg4 }}</button>
