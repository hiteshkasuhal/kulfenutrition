<script src="{{ 'custom_header.js' | asset_url }}" async="async"></script>
{{ 'custom_header.css' | asset_url | stylesheet_tag: preload: true }}
{%- style -%}
{% if section.settings.bg != blank %}
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: bottom;
    }
  {% endif %}
{% if section.settings.bg_mobile != blank %}
  @media screen and (max-width: 915px) {
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg_mobile | image_url}});
    }
  }
  {% endif %}
  @media screen and (max-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  @media screen and (min-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.bg2 != blank %}
    .block_{{ section.id }} {
      background-image:url({{section.settings.bg2 | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: bottom;
    }
  {% endif %}


        
{%- endstyle -%}


<div class=" section_bg_{{ section.id }} custom_header_hk {{ section.settings.custom_class }}"{% if section.settings.custom_id != blank %} id="{{ section.settings.custom_id }}"{% endif %}
style="background-color:{{ section.settings.bg_color | default:'transparent' }}">
   <div class="container_hk section-{{ section.id }}-padding">
     <div class="richtext_blocks_new {{ section.settings.position }} block_{{ section.id }}" style="background-color:{{ section.settings.bg_color2 | default:'transparent' }};color:{{ section.settings.color | default:'#000' }}">
     <div class="header_flex">
      <div class="drawer-button mobile_only" id="drawer-toggle">
        {{ section.settings.svg }}
      </div>
      <div class="header_logo">
{% if section.settings.logo != blank %}
  <a href="{{ shop.url }}">
  <img class="logo" alt="{{ section.settings.logo.alt }}" src="{{ section.settings.logo | image_url }}" loading="eager" width="auto" height="auto" fetchpriority="high" preload="true">
  </a>
  {% endif %}
      </div>
      
{% if section.settings.menu != blank %}
 <div class="header_menu_lp_desktop desktop_only">
    {% for link in section.settings.menu.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>
  {% endif %}
      <div class="header_icons_lp">
        <div class="header_form desktop_only">
        {% form 'localization' %}
  <select name="country_code" id="country_selector_header">
    {% assign current_country = localization.country %}
    <option value="{{ current_country.iso_code }}">
      {{ current_country.currency.iso_code }} {{ current_country.currency.symbol }}
    </option>

    {% for country in localization.available_countries %}
      {% unless country.iso_code == current_country.iso_code %}
        <option value="{{ country.iso_code }}">
          {{ country.currency.iso_code }} {{ country.currency.symbol }}
        </option>
      {% endunless %}
    {% endfor %}
  </select>
{% endform %}

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const selector = document.getElementById("country_selector_header");
    if (selector) {
      selector.addEventListener("change", function () {
        this.form.submit();
      });
    }
  });
</script>
</div>
{% if section.settings.account_icon != blank %}
  <a class="account_icon_lp desktop_only" href="/account">{{ section.settings.account_icon }}</a>
{%endif %}
{% if section.settings.search_icon != blank %}
  <a class="search_icon_lp desktop_only" href="/search">{{ section.settings.search_icon }}</a>
{%endif %}

      <div class="header_cart_toggle" id="cart-toggle">
        <span class="cart_count_js"{% if cart.item_count == 0 %} style="display:none;"{% endif %}>{{ cart.item_count }}</span>
        {{ section.settings.svg3 }}
      </div>
     </div>
    </div>
       
     </div>
   </div>
  </div>

<!-- Drawer Menu -->
<div id="menu-drawer" class="drawer" style="background-color:{{ section.settings.bg_color | default:'transparent' }};color:{{ section.settings.color | default:'#000' }}">
