  <path d="M51 0L52.3507 4.14088L56.7063 4.1459L53.1855 6.71012L54.5267 10.8541L51 8.298L47.4733 10.8541L48.8145 6.71012L45.2937 4.1459L49.6493 4.14088L51 0Z" fill="#1A2D95"/>
  <path d="M66 0L67.3507 4.14088L71.7063 4.1459L68.1855 6.71012L69.5267 10.8541L66 8.298L62.4733 10.8541L63.8145 6.71012L60.2937 4.1459L64.6493 4.14088L66 0Z" fill="#1A2D95"/>
</svg><span>4.8 / 5.0</span></div> 
      <div class="recommended_product_single_title">{{ recommended_product.title }}</div> 
        </div>
      <div class="recommended_product_right_title_right">
        {% if recommended_product.compare_at_price > recommended_product.price %}
          <div class="recommended_product_save">Save {{ recommended_product.compare_at_price | minus: recommended_product.price | money_without_trailing_zeros }}</div>
          {% endif %}
          <div class="recommended_product_price_flex">
        {% if recommended_product.compare_at_price > recommended_product.price %}
      <div class="recommended_product_price_compare">{{ recommended_product.compare_at_price  | money }}</div>
          {% endif %}
      <div class="recommended_product_price">{{ recommended_product.price | money }}</div>
          </div>
      </div>
      </div>
      <div class="recommended_product_bottom_flex">
      <div class="recommended_product_bottom_left">
      
      </div>
      <div class="recommended_product_right_bottom_right">
        <div class="recommended_product_atc">
        <div class="recommended_product_button" variant_id="{{ recommended_product.variants[1].id }}" quantity="1"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
  <path d="M4 1.33203L2 3.9987V13.332C2 13.6857 2.14048 14.0248 2.39052 14.2748C2.64057 14.5249 2.97971 14.6654 3.33333 14.6654H12.6667C13.0203 14.6654 13.3594 14.5249 13.6095 14.2748C13.8595 14.0248 14 13.6857 14 13.332V3.9987L12 1.33203H4Z" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M2 4H14" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M10.6685 6.66797C10.6685 7.37521 10.3876 8.05349 9.88749 8.55359C9.38739 9.05368 8.70912 9.33464 8.00187 9.33464C7.29463 9.33464 6.61635 9.05368 6.11625 8.55359C5.61616 8.05349 5.33521 7.37521 5.33521 6.66797" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div>
        </div>
      </div>
      </div>
      </div>
      </div>
      </div>
{%endfor %}

      </div>
           <div class="slider_navigations center">
  <div class="slider_button_custom custom_prev prev_{{ section.id }}"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
  <path d="M10 3.5L5 8.5L10 13.5" stroke="#1A2D95" stroke-opacity="1" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div>
       <div class="slider_dots_custom dots_{{ section.id }}"></div>
  <div class="slider_button_custom custom_next next_{{ section.id }}"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
  <path d="M6 12.5L10 8.5L6 4.5" stroke="#1A2D95" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div> 
     </div>
     <script>
    $('.slider_{{ section.id }}').slick({
  dots: true,
  speed: 300,
  slidesToShow: 1,
  slidesToScroll: 1,
  autoplay: false,
  infinite: true,
    prevArrow: $('.prev_{{ section.id }}'),
    nextArrow: $('.next_{{ section.id }}'),
    appendDots: $('.dots_{{ section.id }}'),
  cssEase:'linear',
  responsive: [
    {
      breakpoint: 915,
      settings: {
        speed: 300,
        slidesToShow:1,
      }
    }
  ]
});
  
</script>
          {% endif %}
          </div>
          {% endif %}
      </div>

      
  {%- assign total_original = 0 -%}
 {%- for li in cart.items -%}
      {%- assign total_final = total_final | plus: li.final_line_price -%}
      {% if li.variant.compare_at_price  > li.variant.price %}
      {%- assign compare_orignal = li.variant.compare_at_price | times: li.quantity -%}
      {%- assign total_original = total_original | plus: compare_orignal -%}
      {% else %}
      {%- assign total_original = total_original | plus: li.original_line_price -%}
      {% endif %}
  {%- endfor -%}


    <div class="cart_footer">
    <div class="cart_footer_top">
    <div class="cart_footer_subtotal_title">{{ section.settings.subtotal }} {{ cart.item_count }} {% if cart.item_count > 1 %}Items{%else %} Item{%endif %}</div>
    <div class="cart_footer_subtotal_right">
      {% if total_original  > cart.total_price %}
    <div class="cart_footer_subtotal_save">Save {{ total_original | minus:cart.total_price | money }}</div>
      {% endif %}
    <div class="cart_footer_subtotal_price">{% if total_original > cart.total_price %}<s>{{ total_original | money }}</s> {% endif %}{{ cart.total_price | money }} </div>
    </div>
    </div>


    <div class="cart_footer_button">
      <a href="/checkout" class="checkout_button"><svg xmlns="http://www.w3.org/2000/svg" width="12" height="18" viewBox="0 0 12 18" fill="none">
