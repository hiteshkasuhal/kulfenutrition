{% schema %}
  {
    "name": "Custom header",
    "settings": [
       {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    },
    {
      "type": "liquid",
      "id": "svg",
      "label": "Menu Svg"
    },
    {
      "type": "liquid",
      "id": "svg2",
      "label": "Menu Svg Close"
    },
    {
      "type": "liquid",
      "id": "svg3",
      "label": "Cart Svg"
    },
    {
      "type": "liquid",
      "id": "svg4",
      "label": "Cart Svg Close"
    },
    {
      "type": "liquid",
      "id": "account_icon",
      "label": "Account Icon"
    },
    {
      "type": "liquid",
      "id": "search_icon",
      "label": "Search Icon"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "inline_richtext",
      "id": "cart_title",
      "label": "Cart Title",
      "default":"Your Cart ([count])"
    },
    {
      "type": "inline_richtext",
      "id": "cart_title1",
      "label": "Cart Empty Title",
      "default":"Your Cart Is Empty"
    },
    {
      "type": "inline_richtext",
      "id": "empty_button",
      "label": "Cart Empty Button",
      "default":"Continue Shopping"
    },
    {
      "type": "liquid",
      "id": "rating_svg",
      "label": "Cart Rating Svg"
    },
    {
      "type": "inline_richtext",
      "id": "rating_text",
      "label": "Cart Text"
    },
    {
      "type": "number",
      "id": "threshold",
      "label": "Free Shipping Threshold",
      "default":200
    },
    {
      "type": "liquid",
      "id": "shipping_svg",
      "label": "Free Shipping Svg"
    },
    {
      "type": "liquid",
      "id": "shipping_svg2",
      "label": "Free Shipping Achieve Svg"
    },
    {
      "type": "inline_richtext",
      "id": "shipping_unlocked",
      "label": "Free Shipping Unlocked",
      "default":"<strong>Congrats!</strong> You have unlocked <strong>FREE Shipping!</strong>"
    },
    {
      "type": "inline_richtext",
      "id": "shipping_locked",
      "label": "Free Shipping Locked",
      "default":"Add <strong>[price]</strong> to unlock <strong>FREE Shipping!</strong>"
    },
    {
      "type": "inline_richtext",
      "id": "recommended_title",
      "label": "Recommended Title",
      "default":"You may like "
    },
    {
      "type": "product_list",
      "id": "recommended_product",
      "label": "Recommended Products"
    },
    {
      "type": "inline_richtext",
      "id": "subtotal",
      "label": "Subtotal Title",
      "default":"Subtotal: "
    },
    {
      "type": "inline_richtext",
      "id": "checkout",
      "label": "Checkout Title",
      "default":"secure checkout"
    },
    {
      "type": "liquid",
      "id": "under_svg1",
      "label": "Svg1"
    },
    {
      "type": "inline_richtext",
      "id": "under_text1",
      "label": "Text1"
    },
    {
      "type": "liquid",
      "id": "under_svg2",
      "label": "Svg2"
    },
    {
      "type": "inline_richtext",
      "id": "under_text2",
      "label": "Text2"
    },
    {
      "type": "image_picker",
      "id": "payments",
      "label": "payments"
    },
      {
      "type": "image_picker",
      "id": "bg",
      "label": "Section Background"
    },
      {
      "type": "image_picker",
      "id": "bg_mobile",
      "label": "Section Background"
    },
     {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color"
    },
      {
      "type": "image_picker",
      "id": "bg2",
      "label": "Section Block Background"
    },
     {
      "type": "color",
      "id": "bg_color2",
      "label": "Section Block Background Color"
    },
     {
      "type": "color",
      "id": "color",
      "label": "Section Block Text Color"
    },
    {
      "type": "select",
      "id": "position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content position"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 50
    }
    ],
  "presets": [
    {
      "name": "Custom header"
    }
  ]
  }
{% endschema %}