</svg> {{ section.settings.checkout }}</a>
    </div>
    
    <div class="under_cta_texts">
    <div class="under_cta_text">{{ section.settings.under_svg1 }}
      <span>{{ section.settings.under_text1 }}</span>
    </div>
    <div class="under_cta_text">{{ section.settings.under_svg2 }}
      <span>{{ section.settings.under_text2 }}</span>
    </div>
    </div>
{% if section.settings.payments != blank %}
  <div class="cart_paymants">
  <img class="payments_icons" alt="{{ section.settings.payments.alt }}" src="{{ section.settings.payments | image_url }}" loading="eager" width="auto" height="auto" fetchpriority="high">
  </div>
  {% endif %}
    </div>
  </div>
    {% endif %}
  </div>
</div>
