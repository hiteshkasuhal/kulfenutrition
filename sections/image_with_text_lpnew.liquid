            {%- when 'table_slider' -%}
      <div class="table_slider_main {{ block.settings.custom_class }}">
      <div class="table_slider_main_left">
            {% if block.settings.image != blank %}
              <div  class="rich-text_custom__image  {{ block.settings.custom_class }}" {{ block.shopify_attributes }} >
  <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}">
          </div>
              {% endif %}
      </div>
      <div class="table_slider_main_right">
       <div class="table_slider_main_right_slider slider_{{ block.id }}  custom_slick_slider"> 
         {% if block.settings.image2 != blank %}
              <div  class="table_slider_main_right_slider_item">
  <img src="{{ block.settings.image2 | image_url }}" alt="{{ block.settings.image2.alt }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}">
              </div>
              {% endif %}
         {% if block.settings.image3 != blank %}
              <div  class="table_slider_main_right_slider_item">
  <img src="{{ block.settings.image3 | image_url }}" alt="{{ block.settings.image3.alt }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}">
              </div>
              {% endif %}
       </div>
        
     <div class="slider_navigations center">
  <div class="slider_button_custom prev_{{ block.id }} desktop_only mobile_only"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
  <path d="M19 5L10 14L19 23" stroke="#1A2D95" stroke-opacity="0.2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div>
       <div class="slider_dots_custom dots_{{ block.id }}"></div>
  <div class="slider_button_custom next_{{ block.id }} desktop_only mobile_only"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
  <path d="M9 23L18 14L9 5" stroke="#1A2D95" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></div>
     </div>
            
<script>
$('.slider_{{ block.id }}').slick({
  dots: true,
  speed: 300,
  slidesToShow: 1,
  slidesToScroll: 1,
  autoplay: false,
  infinite: false,
    prevArrow: $('.prev_{{ block.id }}'),
    nextArrow: $('.next_{{ block.id }}'),
    appendDots: $('.dots_{{ block.id }}'),
  cssEase:'linear',
  responsive: [
    {
      breakpoint: 915,
      settings: {
        speed: 300,
        slidesToShow:1,
  slidesToScroll: 1, 
      }
    }
  ]
});
</script>
      </div>
        
      </div>

            {% when 'two_image_with_text' %}
                  {% if block.settings.image1 != blank %}
              <div  class="custom_icons_with_text_landing_page {{ block.settings.custom_class }}">
                <div class="image_with_text_item">
                <div class="image_with_text_item_left left">
                  {% if block.settings.image1 != blank %}
                  <img src="{{ block.settings.image1 | image_url }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}" alt="{{ block.settings.image1.alt }}" {% if block.settings.image1_mobile != blank %} class="desktop_only"{% endif %}>  
                  {% endif %}
                  {% if block.settings.image1_mobile != blank %}
                  <img src="{{ block.settings.image1_mobile | image_url }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}" alt="{{ block.settings.image1_mobile.alt }}" class="mobile_only">  
                  {% endif %}
                  {% if block.settings.text1 != blank %}
                    <div class="image_with_text_item_text">{{ block.settings.text1 }}</div>
                  {% endif %}
                </div>
                <div class="image_with_text_item_right">
                  {% if block.settings.image2 != blank %}
                  <img src="{{ block.settings.image2 | image_url }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}" alt="{{ block.settings.image2.alt }}" {% if block.settings.image2_mobile != blank %} class="desktop_only"{% endif %}>  
                  {% endif %}
                  {% if block.settings.image2_mobile != blank %}
                  <img src="{{ block.settings.image2_mobile | image_url }}" width="auto" height="auto" fetchpriority="{{ block.settings.fetchpriority }}" loading="{{ block.settings.loading }}" alt="{{ block.settings.image2_mobile.alt }}" class="mobile_only">  
                  {% endif %}
                  {% if block.settings.text2 != blank %}
                    <div class="image_with_text_item_text">{{ block.settings.text2 }}</div>
                  {% endif %}
                </div>
                 </div>
              </div>
            {% endif %}
            {% endcase %}
       {% endfor %}
     </div>


       {% if section.settings.position_image == 'right' %}
         <div class="image_with_text_image image_block_{{ section.id }}">
         {% if section.settings.heading1 != blank %}
              <h2 class="rich-text_custom__heading  inline-richtext h1 custom_heading_top">{{ section.settings.heading1 }}</h2>
              {% endif %} 
           {% if section.settings.image != blank %}
  <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.image.alt }}" width="auto" height="auto" fetchpriority="{{ section.settings.fetchpriority }}" loading="{{ section.settings.loading }}" {% if section.settings.image_mobile != blank %} class="desktop_only"{% endif %}>
            {% if section.settings.image_mobile != blank %}
  <img src="{{ section.settings.image_mobile | image_url }}" alt="{{ section.settings.image_mobile.alt }}" width="auto" height="auto" fetchpriority="{{ section.settings.fetchpriority }}" loading="{{ section.settings.loading }}" class="mobile_only">
              {% endif %}
 {% endif %}
            {% if section.settings.heading2 != blank %}
              <h2 class="rich-text_custom__heading  inline-richtext h1 custom_heading_bottom">{{ section.settings.heading2 }}</h2>
              {% endif %} 
         </div>
       {% endif %}
       
     </div>
   </div>
  </div>


