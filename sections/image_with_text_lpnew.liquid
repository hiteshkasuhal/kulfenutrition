       <div class="slider_dots_custom dots_{{ block.id }}"></div>
  <div class="slider_button_custom custom_next next_{{ block.id }}"><svg xmlns="http://www.w3.org/2000/svg" width="47" height="47" viewBox="0 0 47 47" fill="none">
  <circle cx="23.8975" cy="23.1026" r="23.1026" fill="white"/>
  <path d="M31.6524 24.0635C32.1832 23.5328 32.1832 22.6723 31.6524 22.1416L23.004 13.4931C22.4733 12.9624 21.6128 12.9624 21.0821 13.4931C20.5514 14.0238 20.5514 14.8843 21.0821 15.415L28.7696 23.1025L21.0821 30.7901C20.5514 31.3208 20.5514 32.1812 21.0821 32.712C21.6128 33.2427 22.4733 33.2427 23.004 32.712L31.6524 24.0635ZM30.6914 23.1025V24.4615H30.6915V23.1025V21.7436H30.6914V23.1025Z" fill="black"/>
</svg></div>
     </div>

      
<script>
$('.slider_{{ block.id }}').slick({
  dots: true,
  speed: 300,
  slidesToShow: 1,
  slidesToScroll: 1,
  autoplay: false,
  infinite: true,
    prevArrow: $('.prev_{{ block.id }}'),
    nextArrow: $('.next_{{ block.id }}'),
    appendDots: $('.dots_{{ block.id }}'),
  cssEase:'linear',
  responsive: [
    {
      breakpoint: 915,
      settings: {
        speed: 300,
        slidesToShow:1,
  slidesToScroll: 1, 
      }
    }
  ]
});
</script>
</div>
              {% endif %}


            {% when 'review_slider' %}
            {% if review_slider == false %}
          {% assign review_slider = true %}
              
     <div class="relative">
     <div class="reviews_center_slider_new review_slider_lp ">
       <div class="review_slider_main_slider_new slider_{{ block.id }} custom_slick_slider">
