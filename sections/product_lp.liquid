$('.customize_item_plus').click(function(){

  if($(this).is('[disabled]')) return;

  let parent = $(this).closest('.customize_quantity_item');
  let input = parent.find('input');

  let qty = Number(input.val()) || 0;
  if(getTotal() >= 3) return;

  let variants = parent.hasClass('product1_quantity')
      ? product1Variants
      : product2Variants;

  let newQty = qty + 1;

  if(!variants[newQty-1] || !variants[newQty-1].available){
    return;
  }

  input.val(newQty);

  parent.find('.customize_item_minus').removeAttr('disabled');

  updateButtons();
});

$('.customize_item_minus').click(function(){

  if($(this).is('[disabled]')) return;

  let parent = $(this).closest('.customize_quantity_item');
  let input = parent.find('input');

  let qty = Number(input.val()) || 0;
  if(qty <= 0) return;

  let newQty = qty - 1;

  input.val(newQty);

  if(newQty == 0){
    $(this).attr('disabled', true);
  }

  updateButtons();
});

/* init */
updateButtons();

