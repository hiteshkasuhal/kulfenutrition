<div class="bundle-routine-wrapper">
  <h2 class="bundle_heading">{{ block.settings.heading }}</h2>
  <p class="bundle_text">{{ block.settings.subheading }}</p>
  <div class="bundle_products">
    {% assign total_price = 0 %}
    {% assign total_compare_price = 0 %}
    {% assign variant_ids = '' %}
    {% assign selling_plan_ids = '' %}

    {% for product in block.settings.product_list %}
      {% assign variant = product.variants.first %}
      <div class="product_bundle_item">
        {% if forloop.index == 1 %}
        <img src="{{ block.settings.image1 | image_url }}" alt="{{ product.title }}" width="auto" height="auto" loading="eager" fetchpriority="high">
        {% endif %}
        {% if forloop.index == 2 %}
        <img src="{{ block.settings.image2 | image_url }}" alt="{{ product.title }}" width="auto" height="auto" loading="eager" fetchpriority="high">
        {% endif %}
        {% if forloop.index == 3 %}
        <img src="{{ block.settings.image3 | image_url }}" alt="{{ product.title }}" width="auto" height="auto" loading="eager" fetchpriority="high">
        {% endif %}
        <p class="bundle_product_title">{{ product.title }}</p>
      </div>
      {% assign total_price = total_price | plus: variant.selling_plan_allocations.first.per_delivery_price %}
      {% assign total_compare_price = total_price | plus: variant.price %}
      {% assign variant_ids = variant_ids | append: variant.id | append: ',' %}
      {% if variant.selling_plan_allocations.first.selling_plan.id %}
        {% assign selling_plan_ids = selling_plan_ids | append: variant.selling_plan_allocations.first.selling_plan.id | append: ',' %}
      {% else %}
        {% assign selling_plan_ids = selling_plan_ids | append: 'null,' %}
      {% endif %}
      {% unless forloop.last %}<span class="plus_icon">+</span>{% endunless %}
    {% endfor %}
  </div>

  {% assign discount_amount = total_price | times: block.settings.discount_percent | divided_by: 100 %}
  {% assign discounted_price = total_price | minus: discount_amount %}

  <p class="total_price left">Total Price: <span class="text-[#dd3b3b]">{{ discounted_price | money }}</span> <s class="text-gray-500">{{ total_compare_price | money }}</s></p>
  <div class="custom_add_bundle custom_hk_button" id="add-bundle-to-cart">{{ block.settings.button_label }}</div>
  <p class="delivery_text">
        {% if block.settings.image_delivery != blank %}
        <img src="{{ block.settings.image_delivery | image_url }}" alt="{{ block.settings.image_delivery.alt }}" width="auto" height="auto" loading="eager" fetchpriority="high">
        {% endif %}
       <span>{{ block.settings.delivery_note }}</span>
    
  </p>
  

<script>
  document.getElementById('add-bundle-to-cart')?.addEventListener('click', function () {
    var $btn = $(this).addClass('loading_hk');

    const variantIds = "{{ variant_ids | strip_newlines | strip | replace_last: ',', '' }}".split(',');
    const sellingPlanIds = "{{ selling_plan_ids  | strip_newlines | strip | replace_last: ',', ''  }}".split(',');


    let items = [];
    variantIds.forEach((id, index) => {
      if (id) {
        const payload = {
          id: parseInt(id),
          quantity: 1
        };
        const plan = sellingPlanIds[index];
        if (plan !== 'null' && plan !== '') {
          payload.selling_plan = parseInt(plan);
        }
        items.push(payload);
      }
    });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ items })
    }).then(() => {
      window.location.href = '/cart'; // ✅ Fix: removed accidental comment
      $btn.removeClass('loading_hk');
    }).catch((err) => {
      console.error('Add to cart failed:', err);
    });
  });
</script>
