$(document).on("click", '.trigger_{{ section.id }}', function(e){

  e.preventDefault();

  var $btn = $(this).addClass('loading_hk');

  var id1 = $btn.attr('variant_id');
  var id2 = $btn.attr('variant_id2');

  var quantity = $btn.attr('quantity') || 1;

  var selling_plan1 = $btn.attr('selling_plan1');
  var selling_plan2 = $btn.attr('selling_plan2');

  var items = [];

  if(id1){
    var item1 = {
      id: id1,
      quantity: quantity
    };

    if(selling_plan1){
      item1.selling_plan = selling_plan1;
    }

    items.push(item1);
  }

  if(id2){
    var item2 = {
      id: id2,
      quantity: quantity
    };

    if(selling_plan2){
      item2.selling_plan = selling_plan2;
    }

    items.push(item2);
  }

  if(!items.length){
    $btn.removeClass('loading_hk');
    return;
  }

  $.ajax({
    type: "POST",
    url: "/cart/add.js",
    data: JSON.stringify({ items: items }),
    contentType: "application/json",
    dataType: "json",
    success: function(){

      $.get(window.location.pathname, function(res){

        const $newCartCount = $(res).find('.cart_count_js');
        const cartCount = parseInt($newCartCount.text().trim(), 10);

        if(cartCount > 0){
          $('.cart_count_js').text(cartCount).show();
        }else{
