{% if section.settings.product != blank %}
  {% assign product = section.settings.product %}
{%- style -%}
  {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'product2' -%}
  {% assign product2 = block.settings.product %}
            {% endcase %}
          {% endfor %}
{% if section.settings.bg != blank %}
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: bottom;
    }
  {% endif %}
{% if section.settings.bg_mobile != blank %}
  @media screen and (max-width: 915px) {
    .section_bg_{{ section.id }} {
      background-image:url({{section.settings.bg_mobile | image_url}});
    }
  }
  {% endif %}
  @media screen and (max-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  @media screen and (min-width: 915px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{% assign variant_images = '' %}
{% for variant in product.variants %}
  {% assign variant_images = variant_images | append: variant.featured_image | append: ',' %}
{% endfor %}


{% if section.settings.image_top != blank %}
   <div class="desktop_only curve_top {{ section.settings.custom_class }}">
