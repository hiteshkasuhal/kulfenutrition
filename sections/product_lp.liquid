<script>
function isAnyElementInViewport(selectors) {
  return selectors.some(function(selector) {
    var $el = $(selector);
    return $el.is(':visible') &&
      $(window).scrollTop() + $(window).height() > $el.offset().top &&
      $(window).scrollTop() < $el.offset().top + $el.outerHeight();
  });
}
$(window).on('scroll resize', function () {
  if (!isAnyElementInViewport(['.custom_checkout_button', '.pdp_pdt_heading', '.kulfe_pdt_heading','.option_item', '.product_images', '.hp_copyright, .subscription_item', '.kulfe_section1_button'])) {
