<script>
$(document).ready(function(){

function getQty(selector){
  return Number($(selector).find('input').val()) || 0;
}

function getTotal(){
  return getQty('.product1_quantity') + getQty('.product2_quantity');
}

function getVariant(productVariants, qty){

  if(qty == 0) return null;

  let index = qty - 1;

  if(productVariants[index] && productVariants[index].available){

    let variant = productVariants[index];

    let sellingPlan = null;

    if(variant.selling_plan_allocations && variant.selling_plan_allocations.length){
      sellingPlan = variant.selling_plan_allocations[0].selling_plan_id;
    }

    return {
      variant_id: variant.id,
      selling_plan: sellingPlan
    };
  }

  return null;
}

function updateVariants(){

  let q1 = getQty('.product1_quantity');
  let q2 = getQty('.product2_quantity');

  let variant1 = getVariant(product1Variants, q1);
  let variant2 = getVariant(product2Variants, q2);

  $('.custom_checkout_button')
    .attr('variant_id', variant1 ? variant1.variant_id : '')
    .attr('variant_id2', variant2 ? variant2.variant_id : '')
    .attr('selling_plan', variant1 ? variant1.selling_plan : '')
    .attr('selling_plan2', variant2 ? variant2.selling_plan : '');
var selected_tab = $('.subscription_item.active').attr('data_tab');
if (selected_tab == '1'){
$('.trigger_{{ section.id }}').removeAttr('selling_plan');
$('.trigger_{{ section.id }}').removeAttr('selling_plan2');
}
}
