                  <script>
                    $('.slider_{{ block.id }}').slick({
                      dots: true,
                      speed: 300,
                      slidesToShow: 2,
                      slidesToScroll: 1,
                      autoplay: false,
                      infinite: true,
                    adaptiveHeight: true,
                        prevArrow: $('.prev_{{ block.id }}'),
                        nextArrow: $('.next_{{ block.id }}'),
                        appendDots: $('.dots_{{ block.id }}'),
                      cssEase:'linear',
                      responsive: [
                        {
                          breakpoint: 915,
                          settings: {
                            speed: 300,
                            slidesToShow:1,
                      slidesToScroll: 1,
                          }
                        }
                      ]
                    });
                  </script>


