  let q2 = getQty('.product2_quantity');
  let total = q1 + q2;

  if(total >= 3){
    $('.customize_item_plus').attr('disabled', true);
  }else{
    $('.customize_item_plus').removeAttr('disabled');
  }

  if(total > 0){

    $('.option_item').removeClass('active');
