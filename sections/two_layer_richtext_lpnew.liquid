                {%- endif -%}
                <script>

$(document).on("click", '.trigger_{{ block.id }}', function(e) {
e.preventDefault(); 
var this_element =  jQuery(this);
this_element.addClass('loading_hk');
var id = jQuery(this).attr('variant_id');
var current_url = location.href;

jQuery.ajax({
type: 'POST',
url: '/cart/add.js',
data: {
  quantity: 1,
  id: id
},
  dataType: 'json', 
 success: function (data) { 
   $.ajax({
        url: current_url,
        data: "",
        type: "GET",
        dataType: "html",
        success: function (data) {
$(".quick-cart__wrapper").html($(".quick-cart__wrapper", data).html());
$(".lp_cart_icon").html($(".lp_cart_icon", data).html());
$('.quick-cart').addClass('animation--quick-cart-revealed');
$('.quick-cart__wrapper').addClass('active');
$('body').attr('data-fluorescent-overlay-open','true');
this_element.removeClass('loading_hk'); 
        },
        error: function (xhr, status) {},
        complete: function (xhr, status) {},
      }); 
 } 
 });
  });
                  
