<style>
  .container-before-after_{{ block.id }} {
    display: grid;
    place-content: center;
    position: relative;
    overflow: hidden;
    --position: 50%;
  }
  
  .image-container_{{ block.id }} {
    aspect-ratio: 1/1;
	aspect-ratio:{{ block.settings.before.width }}/{{ block.settings.before.height }};
    position: relative;
    border-radius: 0px !important;
    overflow: hidden;
    margin: 1px;
  }
  
  .slider-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left;
    border-radius: 0;
  }
  
  .image-before {
    position: absolute;
    inset: 0;
    width: var(--position);
    /* filter: grayscale(100%); */
  }
  
  .slider-before-after_{{ block.id }} {
    position: absolute;
    inset: 0;
    cursor: pointer;
    opacity: 0;
    width: 100%;
    height: 100%;
  }
  
  .container-before-after .slider-line {
    display: block;
    position: absolute;
    inset: 0;
    width: .4rem;
    height: 100%;
    background-color: #000;
    left: var(--position);
    transform: translateX(-50%);
    pointer-events: none;
  }
  
