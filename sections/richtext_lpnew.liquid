{%if section.settings.custom_class contains 'custom_slider_activate' %}
  <div class="richtext_slider_item">
  {% endif %}
          {%- case block.type -%}

            {% when 'tab_trigger' %}
            {% if tabs_trigger == false %}
{% assign tabs_trigger = true %}
       
          {% assign first_tab_id = "" %}
          {% assign tab_loop = 0 %}
               <div class="trigger_tabs_main tabs_{{ section.id }}">
        <div class="trigger_tabs_flex">
          {% assign first_tab_id = "" %}
          {% assign tab_loop = 0 %}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {% when 'tab_trigger' %}
  {% assign tab_loop = tab_loop | plus: 1 %}
            {% if tab_loop == 1 %}
          {% assign first_tab_id = block.settings.id %}
              {% endif %}
        <div class="trigger_tabs_item_inner">
        <div class="trigger_tabs_item{% if tab_loop == 1 %} active{% endif %}" data_tab="{{ block.settings.id }}">
          {% if block.settings.image != blank %}
             <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt }}" width="auto" height="auto" fetchpriority="high" loading="eager">
      {% endif %}
            <div class="tab_texts">
          {% if block.settings.title != blank %}
            <div class="tab_title">{{ block.settings.title }}</div>
              {% endif %}
          {% if block.settings.text != blank %}
            <div class="tab_text">{{ block.settings.text }}</div>
              {% endif %}
            </div>
        </div>
        </div>
            {% endcase %}
          {% endfor %}
        </div>
        </div>
<style>
  .{{section.settings.trigger_class}}:not(#{{first_tab_id}}) {
    display:none;
  }
</style>
<script>
 jQuery('.tabs_{{ section.id }} .trigger_tabs_item').click(function(){
    jQuery('.tabs_{{ section.id }} .trigger_tabs_item').removeClass('active');
   jQuery(this).addClass('active');
    var id = jQuery(this).attr('data_tab');
    jQuery('.{{ section.settings.trigger_class }}').hide();
    jQuery('#'+id).show();
    jQuery('#'+id).find('.slick-slider').slick('refresh');
});
</script>
