ojects/71c1cd91-efd0-4561-805d-b66a5bcaf378/19559425-4e0c-4d2e-b429-323d1410f6ff?width=60" media="(min-width: 641px) and (max-width: 1024px)"/><source srcSet="https://assets.replocdn.com/projects/71c1cd91-efd0-4561-805d-b66a5bcaf378/19559425-4e0c-4d2e-b429-323d1410f6ff?width=60" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://assets.replocdn.com/projects/71c1cd91-efd0-4561-805d-b66a5bcaf378/19559425-4e0c-4d2e-b429-323d1410f6ff" class="r-pggtb2" loading="eager"/></picture><div data-rid="fa053341-b336-47c9-854b-a7b5490b175e" class="r-12p6ebd alchemy-rte"><span style="width:100%">Sourced from quality dairy suppliers</span></div></div></div></div></div><div data-rid="5cc33f37-1e00-4850-beef-ea1764b9fa7b" data-alchemy-url-hashmark="buyboxmobile" tabindex="-1" id="buyboxmobile" data-alchemy-url-hashmark-ignore="true" class="r-ggv3an">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% assign reploOriginalProductRcb2 = product %}<!-- -->{% capture productHandle %}falooda-whey-isolate-protein-powder{% endcapture %}<!-- -->{% assign product = all_products[productHandle] %}<!-- -->{% assign reploOriginalProductVariantRcb2 = reploSelectedVariant %}<!-- -->{% assign reploSelectedVariant = blank %}<!-- -->{% assign reploOriginalSPGRcb2 = reploSortedSellingPlans %}<!-- -->{% assign reploSortedSellingPlans = blank %}<!-- -->{% assign reploOriginalSSPRcb2 = reploSelectedSellingPlan %}<!-- -->{% assign reploSelectedSellingPlan = blank %}<!-- -->{% assign reploOriginalSSPPriceRcb2 = reploSelectedSellingPlanPrice %}<!-- -->{% assign reploSelectedSellingPlanPrice = blank %}<!-- -->{% assign reploOriginalComparePricePercentRcb2 = reploCompareAtPriceDifferencePercentage %}<!-- -->{% assign reploCompareAtPriceDifferencePercentage = blank %}<!-- -->{%- comment -%}replo-liquid-chunk-end{%- endcomment -%}<!-- -->{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% capture reploVariantIdString %}51031342285093{% endcapture %}<!-- -->{% capture reploSellingPlanIdString %}null{% endcapture %}<!-- -->{% capture reploIdKey %}id{% endcapture %}<!-- -->{% capture reploPercentageKey %}percentage{% endcapture %}<!-- -->{% capture reploPriceKey %}price{% endcapture %}<!-- -->{% capture reploFixedAmountKey %}fixed_amount{% endcapture %}<!-- -->{% capture spKey %}selling_plan{% endcapture %}<!-- -->{%- liquid
              assign reploVariantId = reploVariantIdString | times: 1
              assign reploSelectedVariant = product.variants | where: reploIdKey, reploVariantId | first
              if reploSelectedVariant == blank
                assign reploSelectedVariant = product.selected_or_first_available_variant
              endif
              assign reploSelectedSellingPlanPrice = reploSelectedVariant.price
              if product.selling_plan_groups[0]
                assign reploAllSellingPlans = reploSelectedVariant.selling_plan_allocations | map: spKey
                assign reploSortedSellingPlans = reploAllSellingPlans | sort: reploIdKey
                if true
                  assign reploSellingPlanId = reploSellingPlanIdString | times: 1
                  assign reploSelectedSellingPlan = reploSortedSellingPlans | where: reploIdKey, reploSellingPlanId | first
                  if reploSelectedSellingPlan.price_adjustments[0]
                    assign adjustment = reploSelectedSellingPlan.price_adjustments[0]
                    case adjustment.value_type
                      when reploPercentageKey
                        assign amountOff = 100 | minus: adjustment.value
                        assign reploSelectedSellingPlanPrice = reploSelectedSellingPlanPrice | times: amountOff | divided_by: 100
                      when reploFixedAmountKey
                        assign reploSelectedSellingPlanPrice = reploSelectedSellingPlanPrice | minus: adjustment.value
                      when reploPriceKey
                        assign reploSelectedSellingPlanPrice = adjustment.value
                    endcase
                  endif
